# [DEPRECATED — currently unused]
#
# Enforces "traffic must come from Cloudflare proxy IPs". Only makes sense when
# sites are orange-clouded (CF proxy ON). Current setup uses gray cloud (DNS
# only) so origin sees real client IPs directly — this matcher would 403 every
# legitimate request.
#
# Kept as documentation. To re-enable orange-cloud mode:
#   1. Switch DNS record back to proxied (orange) on Cloudflare
#   2. Restore `trusted_proxies cloudflare` in Caddyfile global block
#   3. Re-import CLOUDFLARE_ONLY in each site, drop KR_ONLY (CF handles geo)
#
# IP list = Cloudflare proxy IP ranges (IPv4 + IPv6). Source:
# https://www.cloudflare.com/ips/ — Caddy's `remote_ip` matcher accepts no
# dynamic source, so refresh manually when CF publishes new ranges (rare).
(CLOUDFLARE_ONLY) {
	@not_cloudflare {
		not remote_ip \
			103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 \
			104.16.0.0/13 104.24.0.0/14 108.162.192.0/18 \
			131.0.72.0/22 141.101.64.0/18 162.158.0.0/15 \
			172.64.0.0/13 173.245.48.0/20 188.114.96.0/20 \
			190.93.240.0/20 197.234.240.0/22 198.41.128.0/17 \
			2400:cb00::/32 2606:4700::/32 2803:f800::/32 \
			2405:b500::/32 2405:8100::/32 2a06:98c0::/29 \
			2c0f:f248::/32
	}
	respond @not_cloudflare "Access Denied" 403
}
