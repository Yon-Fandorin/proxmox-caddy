# Copy to .env and fill in real values. Never commit .env.

# ACME registration email (Let's Encrypt expiry notices, etc.)
ACME_EMAIL=

# Cloudflare API token with Zone:Read + DNS:Edit on the target zone.
# Used by Caddy for ACME DNS-01 challenges.
CLOUDFLARE_API_TOKEN=

# Apex domain shared across all sites. Per-site hostnames are built as
# {SERVICE_SUBDOMAIN}.{DOMAIN} inside each sites/*.caddy file.
DOMAIN=

# Subdomain for the Proxmox web UI (final host = ${PVE_SUBDOMAIN}.${DOMAIN}).
PVE_SUBDOMAIN=pve

# LAN address + port of the Proxmox web UI (Caddy reverse_proxy upstream).
PVE_HOST=
PVE_PORT=8006
